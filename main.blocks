type="typescript_statement" id="c{BevCV9;g5+13WM7hGx"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let ship: Sprite = null" numlines="1" declaredvars="ship"></mutation><next><block type="typescript_statement" id="P4#Ew%e0tg0lv:cc4_gc"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let asteroids: Image[] = []" numlines="1" declaredvars="asteroids"></mutation><next><block type="typescript_statement" id=":9#dM3i%ke7qR}6Cm^4*"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let level = 0" numlines="1" declaredvars="level"></mutation><next><block type="typescript_statement" id="m1KJf/i{S~ru%+b@dQ1H"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let foodY = 0" numlines="1" declaredvars="foodY"></mutation><next><block type="typescript_statement" id="jIGtPB9l(acHWN]/XlK6"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let foodX = 0" numlines="1" declaredvars="foodX"></mutation><next><block type="typescript_statement" id="MnS]|MXs+-cnugLk!H[Z"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let dy = 0" numlines="1" declaredvars="dy"></mutation><next><block type="typescript_statement" id="GQvCO{rx1|zwa9mR?Q!?"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace projectImages {" line1="    export const stalagmite_small = image.ofBuffer(hex``);" line2="    export const stalagmite_med = image.ofBuffer(hex``);" line3="    export const stalagmite_large = image.ofBuffer(hex``);" line4="    export const stalagmite_xlarge = image.ofBuffer(hex``);" line5="    export const stalagtite_small = image.ofBuffer(hex``);" line6="    export const stalagtite_med = image.ofBuffer(hex``);" line7="    export const stalagtite_large = image.ofBuffer(hex``);" line8="    export const stalagtite_xlarge = image.ofBuffer(hex``);" line9="}" numlines="10"></mutation><next><block type="typescript_statement" id="?VP*7zhhRrF:1oodt(-l"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace lighting {" line1="    let bandPalettes: Buffer[]" line2="    const palette_ramps = image.ofBuffer(hex`e4100400ffff0000d1cb0000a2ff0000b3fc0000e4fc000045ce000086fc000067c80000c8ff000069c80000bafc0000cbff0000fcff0000bdfc0000ceff0000ffff0000`)" line3="" line4="    export interface LightAnchor { x: number; y: number }" line5="" line6="    export class LightSource {" line7="        anchor: LightAnchor" line8="        offsetTable: Buffer" line9="        width: number" line10="        height: number" line11="        constructor(public rings: number, public bandWidth: number, public centerRadius: number) {" line12="            const halfh = centerRadius + rings * bandWidth" line13="            this.offsetTable = pins.createBuffer((rings + 1) * halfh)" line14="            let x: number, band: number, y2: number" line15="            for (let y = 0; y &lt; halfh; y++) {" line16="                y2 = Math.pow(y, 2)" line17="                for (band = 0; band &lt; rings; band++) {" line18="                    x = Math.sqrt(Math.pow(centerRadius + bandWidth * (band + 1), 2) - y2) | 0" line19="                    this.offsetTable[y * rings + band] = x" line20="                }" line21="            }" line22="            this.width = halfh" line23="            this.height = halfh" line24="        }" line25="        apply() {" line26="            const halfh2 = this.width" line27="            const cx = this.anchor.x" line28="            const cy = this.anchor.y" line29="            let prev: number, offset: number, band2: number" line30="            screen.fillRect(0, 0, screen.width, cy - halfh2 + 1, 15)" line31="            screen.fillRect(0, cy - halfh2 + 1, cx - halfh2, halfh2 &lt;&lt; 1, 15)" line32="            screen.fillRect(cx + halfh2, cy - halfh2 + 1, screen.width - cx - halfh2, halfh2 &lt;&lt; 1, 15)" line33="            screen.fillRect(0, cy + halfh2, screen.width, screen.height - (cy + halfh2), 15)" line34="            for (let y3 = 0; y3 &lt; halfh2; y3++) {" line35="                band2 = this.rings" line36="                prev = 0" line37="                offset = this.offsetTable[y3 * this.rings + band2 - 1]" line38="                screen.mapRect(cx - halfh2, cy + y3 + 1, halfh2 - offset, 1, bandPalettes[bandPalettes.length - 1])" line39="                screen.mapRect(cx - halfh2, cy - y3, halfh2 - offset, 1, bandPalettes[bandPalettes.length - 1])" line40="                screen.mapRect(cx + offset, cy + y3 + 1, halfh2 - offset, 1, bandPalettes[bandPalettes.length - 1])" line41="                screen.mapRect(cx + offset, cy - y3, halfh2 - offset, 1, bandPalettes[bandPalettes.length - 1])" line42="                while (band2 &gt; 0) {" line43="                    offset = this.offsetTable[y3 * this.rings + band2 - 1]" line44="                    if (offset) offset += (Math.idiv(Math.randomRange(0, 11), 5))" line45="                    screen.mapRect(cx + offset, cy + y3 + 1, prev - offset, 1, bandPalettes[band2 - 1])" line46="                    screen.mapRect(cx - prev, cy + y3 + 1, prev - offset, 1, bandPalettes[band2 - 1])" line47="                    screen.mapRect(cx + offset, cy - y3, prev - offset, 1, bandPalettes[band2 - 1])" line48="                    screen.mapRect(cx - prev, cy - y3, prev - offset, 1, bandPalettes[band2 - 1])" line49="                    prev = offset" line50="                    band2--" line51="                }" line52="            }" line53="        }" line54="    }" line55="" line56="    export class LanternEffect implements effects.BackgroundEffect {" line57="        protected sources: LightSource[]" line58="        protected static instance: LanternEffect" line59="        protected anchor: LightAnchor" line60="        protected init: boolean" line61="        public static getInstance() {" line62="            if (!LanternEffect.instance) LanternEffect.instance = new LanternEffect()" line63="            return LanternEffect.instance" line64="        }" line65="        private constructor() {" line66="            bandPalettes = []" line67="            for (let band3 = 0; band3 &lt; 6; band3++) {" line68="                const buffer = pins.createBuffer(16)" line69="                for (let i = 0; i &lt; 16; i++) buffer[i] = palette_ramps.getPixel(i, band3 + 1)" line70="                bandPalettes.push(buffer)" line71="            }" line72="            this.sources = []" line73="            this.sources.push(new LightSource(4, 12, 2))" line74="            this.sources.push(new LightSource(4, 13, 1))" line75="            this.sources.push(new LightSource(4, 13, 2))" line76="            this.setAnchor({ x: screen.width &gt;&gt; 1, y: screen.height &gt;&gt; 1 })" line77="        }" line78="        startScreenEffect() {" line79="            if (this.init) return" line80="            this.init = true" line81="            let index = 0" line82="            game.eventContext().registerFrameHandler(91, () =&gt; { this.sources[index].apply() })" line83="            let up = true" line84="            game.onUpdateInterval(1000, () =&gt; {" line85="                if (up) index++; else index--" line86="                if (index &lt; 0) { index = 1; up = true }" line87="                else if (index &gt;= this.sources.length) { index = this.sources.length - 2; up = false }" line88="            })" line89="        }" line90="        setAnchor(anchor: LightAnchor) {" line91="            this.anchor = anchor" line92="            this.sources.forEach((value: LightSource) =&gt; { value.anchor = this.anchor })" line93="        }" line94="    }" line95="}" numlines="96"></mutation><next><block type="function_call" id="ulA8JFEGW$vc_b,M)-;*"><mutation name="showMainMenu" functionid="/az~HDDF1T!bv9hg|,6q"></mutation><comment pinned="false" h="80" w="160">============================================================
