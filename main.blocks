="            speed = 1 / (level / 2 + 2)" line10="            dx = 1; dy = 0" line11="        } else {" line12="            music.playSound(music.sounds(Sounds.BaDing))" line13="        }" line14="        do {" line15="            foodX = randint(1, w - 2)" line16="            foodY = randint(1, h - 2)" line17="        } while (inSnake(foodX, foodY))" line18="    }" numlines="19"></mutation><next><block type="variables_set" id="{Ze~%1xNdya~?o$pc4Nh"><field name="VAR" id="2q[`*-]fq,/pWXc9TN}D">level</field><value name="VALUE"><shadow type="math_number" id="WZrj733hMijH[/m^4uLv"><field name="NUM">1</field></shadow></value><next><block type="variables_set" id="EdV*|#@:aL]d4X;[}P]I"><field name="VAR" id="rwtOOQuR+c0eHf2_3`-b">snake</field><value name="VALUE"><shadow type="math_number" id="Q_`1DAO$~qOco=_aI*|."><field name="NUM">0</field></shadow><block type="lists_create_with" id="TU{f~%v.F6!Z%qTFOdNI"><mutation items="2" horizontalafter="3"></mutation><value name="ADD0"><shadow type="math_number" id="nWvVQW(me|`kY7TuK0t)"><field name="NUM">1541</field></shadow></value><value name="ADD1"><shadow type="math_number" id="YOCq8-oqZRdi^1?/J-r-"><field name="NUM">1285</field></shadow></value></block></value><next><block type="variables_set" id="{a`7,0k@xaz786jvE6+`"><field name="VAR" id="gudkv^Y^!kn|0}/sN/$g">speed</field><value name="VALUE"><shadow type="math_number" id="abS/+]|2lSOJ|rBs]7dh"><field name="NUM">0</field></shadow><block type="math_arithmetic" id="v+/sN*Bc%9OIaYG%y=,p"><field name="OP">DIVIDE</field><value name="A"><shadow type="math_number" id="b3-2NjI*@CY.BprFp1(9"><field name="NUM">1</field></shadow></value><value name="B"><shadow type="math_number" id="k=S$b{IVV$Z9$kMh0HNE"><field name="NUM">0</field></shadow><block type="math_arithmetic" id="2f`_]g~[`Ee[=43V1r3_"><field name="OP">ADD</field><value name="A"><shadow type="math_number" id="ldGiP}y0/72zppqf]qks"><field name="NUM">0</field></shadow><block type="math_arithmetic" id="Ns}jxZIRn1oUwqNSl)Z]"><field